{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Virlen",
  "version": "1.0.0",
  "identifier": "com.virlen.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Virlen 未霖",
        "width": 1000,
        "height": 700,
        "minWidth": 720,
        "minHeight": 500,
        "decorations": false,
        "dragDropEnabled": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/default-skills",
      "resources/quasivision_models"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "signingIdentity": null,
      "providerShortName": null
    }
  }
}